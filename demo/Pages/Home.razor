@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Kinematics — 2D Physics Lab</PageTitle>

<div class="lab">

    <header class="lab-header">
        <span class="lab-title">Kinematics</span>
        <span class="lab-sub">2D Physics Engine</span>
    </header>

    <div class="lab-body">

        <nav class="lab-nav">
            <p class="nav-label">Demos</p>
            @foreach (var scene in _scenes)
            {
                <button class="nav-item @(_active == scene ? "active" : "")"
                        @onclick="() => SelectScene(scene)">
                    <span class="nav-icon">@scene.Icon</span>
                    @scene.Name
                </button>
            }
        </nav>

        <main class="lab-canvas-wrap">
            <canvas id="demo-canvas" width="800" height="560"></canvas>
        </main>

        <aside class="lab-panel">
            <div class="panel-section">
                <p class="panel-label">Scene</p>
                <p class="panel-scene-name">@_active?.Name</p>
                <p class="panel-scene-desc">@_active?.Description</p>
            </div>

            <div class="panel-section">
                <p class="panel-label">Stats</p>
                <div class="stat"><span>Frame</span><span>@_frame</span></div>
                <div class="stat"><span>FPS</span>  <span>@_fps.ToString("F0")</span></div>
                <div class="stat"><span>@_statLabel</span><span>@_statValue.ToString("F2")</span></div>
            </div>

            <div class="panel-section">
                <p class="panel-label">Controls</p>
                <button class="btn-reset" @onclick="ResetScene">↺ Reset</button>
                <p class="hint">Click / tap to push</p>
            </div>

            <div class="panel-section">
                <p class="panel-label">Impulse — @_impulseStrength.ToString("F0") m/s</p>
                <input class="slider" type="range" min="1" max="50" step="1"
                       value="@_impulseStrength"
                       @oninput="e => _impulseStrength = float.Parse(e.Value!.ToString()!)" />
            </div>
        </aside>
    </div>
</div>

@code {
    // ── World constants ────────────────────────────────
    const float WorldW  = 20f;
    const float WorldH  = 14f;
    const int   CanvasW = 800;
    const int   CanvasH = 560;
    const float Scale   = CanvasW / WorldW;   // 40 px/m
    const int   Substeps = 4;                  // physics sub-steps per rendered frame

    // ── Scenes ────────────────────────────────────────
    private readonly List<IDemoScene> _scenes = new()
    {
        new SoftBodyScene(),
        new PressureBodyScene(),
        new ChainScene(),
    };

    private IDemoScene?          _active;
    private KinematicsController _ctrl  = new();
    private DotNetObjectReference<Home>? _selfRef;

    // ── Stats ─────────────────────────────────────────
    private int    _frame;
    private double _fps;
    private string _statLabel = "Pos Y";
    private float  _statValue;
    private double _fpsAccum;
    private int    _fpsFrames;
    private const double FpsInterval = 0.5;

    // ── Impulse ───────────────────────────────────────
    private float _impulseStrength = 10f;         // controlled by slider
    private const float ImpulseRadius = 3f;

    // ── Ripple feedback ───────────────────────────────
    private bool   _ripple;
    private float  _rippleWX, _rippleWY;
    private double _rippleAge;
    private const double RippleDuration = 0.35;

    // ── Lifecycle ─────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _selfRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("Renderer.init", "demo-canvas");
        await JS.InvokeVoidAsync("Renderer.initInteraction", "demo-canvas", _selfRef);
        SelectScene(_scenes[0]);
        await JS.InvokeVoidAsync("GameLoop.start", _selfRef);
    }

    // ── Scene management ──────────────────────────────
    private void SelectScene(IDemoScene scene)
    {
        _ripple    = false;
        _active    = scene;
        _frame     = 0;
        _fpsAccum  = 0;
        _fpsFrames = 0;
        _fps       = 0;
        _ctrl      = new KinematicsController();
        scene.Initialize(_ctrl);
        AddWorldBoundaries(_ctrl);
        _statLabel = scene is ChainScene ? "Low Y" : "Pos Y";
    }

    private void ResetScene()
    {
        if (_active is not null) SelectScene(_active);
    }

    // ── World boundary walls ──────────────────────────
    // Four static bodies forming an arena.  All shapes wound CCW in screen-
    // space (Y-down) so Perpendicular(-Y,X) yields outward normals.
    private static void AddWorldBoundaries(KinematicsController ctrl)
    {
        ctrl.Add(MakeHWall(cx: 0f,     cy: 13.5f)); // bottom
        ctrl.Add(MakeHWall(cx: 0f,     cy:  0.5f)); // top
        ctrl.Add(MakeVWall(cx: -10.5f, cy:  7f));   // left  (3 m thick: x = -12…-9, inner face x = -9)
        ctrl.Add(MakeVWall(cx:  10.5f, cy:  7f));   // right (3 m thick: x =  9…12, inner face x =  9)
    }

    // 20 m wide × 1 m tall, centered; CCW winding
    private static Body MakeHWall(float cx, float cy)
    {
        var s = new Shape();
        s.Begin(true);
        s.Add(new Vector2( 10f, -0.5f));  // top-right
        s.Add(new Vector2(-10f, -0.5f));  // top-left
        s.Add(new Vector2(-10f,  0.5f));  // bottom-left
        s.Add(new Vector2( 10f,  0.5f));  // bottom-right
        s.End();
        return StaticBody(s, cx, cy);
    }

    // 3 m wide × 14 m tall, centered; CCW winding.
    // Extra thickness keeps the inner face always closer to any penetrating PM
    // than the outer face (up to 1.5 m deep), so Collision.Intersects always
    // picks the correct inward normal even at high-velocity impacts.
    private static Body MakeVWall(float cx, float cy)
    {
        var s = new Shape();
        s.Begin(true);
        s.Add(new Vector2(-1.5f, -7f));  // top-left
        s.Add(new Vector2(-1.5f,  7f));  // bottom-left
        s.Add(new Vector2( 1.5f,  7f));  // bottom-right
        s.Add(new Vector2( 1.5f, -7f));  // top-right
        s.End();
        return StaticBody(s, cx, cy);
    }

    private static Body StaticBody(Shape s, float cx, float cy)
    {
        var b = new Body(s, float.PositiveInfinity);
        b.Position = new Vector2(cx, cy);
        b.IsStatic = true;
        return b;
    }

    // ── Pointer callback ──────────────────────────────
    [JSInvokable]
    public void OnPointerDown(float sx, float sy)
    {
        float wx = ToWX(sx), wy = ToWY(sy);
        ApplyImpulse(wx, wy);
        // Start ripple regardless of hit — gives click feedback on misses too
        _ripple    = true;
        _rippleWX  = wx;
        _rippleWY  = wy;
        _rippleAge = 0;
    }

    private void ApplyImpulse(float wx, float wy)
    {
        // ── Soft bodies ───────────────────────────────────────────────────────
        // Push the whole body away from the click point using the click→centre
        // direction so every PM receives the same velocity delta (pure translation).
        //
        // CRITICAL: Body.Update() begins with SetBodyPositionVelocityForce(), which
        // subtracts avg(PM.Velocity) then adds body.Velocity.  If body.Velocity is
        // still the pre-impulse average, that operation strips out the translational
        // component of any impulse we applied.  Calling UpdateBodyPositionVelocityForce()
        // here syncs body.Velocity → the next SetBodyPositionVelocityForce becomes a
        // no-op and the impulse survives intact.
        foreach (Body body in _ctrl.BodyList)
        {
            if (body.IsStatic) continue;

            float dx   = body.Position.X - wx;
            float dy   = body.Position.Y - wy;
            float dist = MathF.Sqrt(dx * dx + dy * dy);
            if (dist < 0.01f || dist > ImpulseRadius) continue;

            float strength = _impulseStrength * (1f - dist / ImpulseRadius);
            float vx = dx / dist * strength;
            float vy = dy / dist * strength;

            foreach (PointMass pm in body.PointMassList)
            {
                pm.Velocity.X += vx;
                pm.Velocity.Y += vy;
            }

            // Sync body.Velocity to the new PM average so the impulse isn't undone.
            body.UpdateBodyPositionVelocityForce();
        }

        // ── Chain links ───────────────────────────────────────────────────────
        // Each link is an independent PM with no body wrapper — push per-PM.
        foreach (Chain chain in _ctrl.ChainList)
            for (int i = 1; i < chain.PointMassList.Count - 1; i++)
                TryPush(chain.PointMassList[i], wx, wy);
    }

    // Per-PM radial push used for chain links.
    private void TryPush(PointMass pm, float wx, float wy)
    {
        float dx   = pm.Position.X - wx;
        float dy   = pm.Position.Y - wy;
        float dist = MathF.Sqrt(dx * dx + dy * dy);
        if (dist < 0.01f || dist > ImpulseRadius) return;

        float strength = _impulseStrength * (1f - dist / ImpulseRadius);
        pm.Velocity.X += dx / dist * strength;
        pm.Velocity.Y += dy / dist * strength;
    }

    // ── Game loop ─────────────────────────────────────
    [JSInvokable]
    public async Task OnFrame()
    {
        const double dt = 1.0 / 60.0;

        // Substep the physics: smaller per-step motion prevents fast bodies from
        // tunneling through thin walls and keeps penetration shallow (so it stays
        // under the resolver's bail-out and gets corrected). PreUpdate forces
        // (gravity, drag) are re-applied each substep so the net impulse over the
        // frame is unchanged.
        double sub = dt / Substeps;
        for (int s = 0; s < Substeps; s++)
        {
            _active?.PreUpdate(_ctrl, sub);
            _ctrl.Update(sub);
        }
        _frame++;

        // FPS
        _fpsAccum  += dt;
        _fpsFrames++;
        if (_fpsAccum >= FpsInterval)
        {
            _fps       = _fpsFrames / _fpsAccum;
            _fpsAccum  = 0;
            _fpsFrames = 0;
        }

        // Stat value
        if (_active is ChainScene)
        {
            float maxY = float.MinValue;
            foreach (Chain c in _ctrl.ChainList)
                foreach (PointMass pm in c.PointMassList)
                    if (pm.Position.Y > maxY) maxY = pm.Position.Y;
            _statValue = maxY;
        }
        else
        {
            foreach (Body b in _ctrl.BodyList)
                if (!b.IsStatic) { _statValue = b.Position.Y; break; }
        }

        // Ripple timer
        if (_ripple)
        {
            _rippleAge += dt;
            if (_rippleAge >= RippleDuration) _ripple = false;
        }

        await RenderAsync();
        await InvokeAsync(StateHasChanged);
    }

    // ── Rendering ─────────────────────────────────────
    private async Task RenderAsync()
    {
        await JS.InvokeVoidAsync("Renderer.clear", "#0d0d1a");

        // Bodies
        foreach (Body body in _ctrl.BodyList)
        {
            var pts = body.PointMassList
                .Select(pm => new { x = ToSX(pm.Position.X), y = ToSY(pm.Position.Y) })
                .ToArray();

            string fill   = body.IsStatic ? "#0a200a" : "#0d1f3a";
            string stroke = body.IsStatic ? "#1e5a1e" : "#4a90e2";
            await JS.InvokeVoidAsync("Renderer.drawPolygon", pts, fill, stroke, 1.5);
        }

        // Chain links
        foreach (Chain chain in _ctrl.ChainList)
        {
            var pms = chain.PointMassList;
            for (int i = 0; i < pms.Count - 1; i++)
                await JS.InvokeVoidAsync("Renderer.drawLine",
                    ToSX(pms[i].Position.X),     ToSY(pms[i].Position.Y),
                    ToSX(pms[i+1].Position.X),   ToSY(pms[i+1].Position.Y),
                    "#c8a040", 2.5);

            for (int i = 0; i < pms.Count; i++)
            {
                bool   anchor = i == 0 || i == pms.Count - 1;
                string fill   = anchor ? "#a06020" : "#c8a040";
                string stroke = anchor ? "#e08040" : "#e0c060";
                await JS.InvokeVoidAsync("Renderer.drawCircle",
                    ToSX(pms[i].Position.X), ToSY(pms[i].Position.Y),
                    anchor ? 7f : 4f, fill, stroke);
            }
        }

        // Ripple at click point — expanding ring that fades out
        if (_ripple)
        {
            float t       = (float)(_rippleAge / RippleDuration);
            float radius  = t * 80f;                // 0 → 80 screen px
            float opacity = 1f - t;
            string color  = $"rgba(255,255,255,{opacity:F2})";
            await JS.InvokeVoidAsync("Renderer.drawCircle",
                ToSX(_rippleWX), ToSY(_rippleWY),
                radius, "transparent", color, 1.5f);
        }
    }

    // ── Coordinate helpers ────────────────────────────
    float ToSX(float wx) => (wx + WorldW / 2f) * Scale;
    float ToSY(float wy) => wy * Scale;
    float ToWX(float sx) => sx / Scale - WorldW / 2f;
    float ToWY(float sy) => sy / Scale;

    // ── Dispose ───────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("GameLoop.stop");
        _selfRef?.Dispose();
    }
}
